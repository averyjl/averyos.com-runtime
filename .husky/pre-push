#!/bin/sh
# AveryOS™ Sovereign Pre-Push Gate — Phase 117 COMMAND 3.2
# ⛓️⚓⛓️ CreatorLock: Jason Lee Avery (ROOT0) 🤛🏻
#
# Runs before every `git push`. Ensures no lint errors or TypeScript issues
# escape into the remote branch / CI.
#
# Gate sequence:
#   1. lint:full — ESLint across the full project (incl. app/ and lib/ at "error" level)
#   2. tsc --noEmit — full TypeScript type-check
#
# DRIFT POLICY (AveryOS™ Constitution Art. 2, 14, 19):
#   There is NO bypass for this gate. Every push must pass 0 errors.
#   If either step fails, resolve the issue BEFORE pushing.

set -e

echo "⛓️ Sovereign Pre-Push: Running lint:full…"
npm run lint:full

echo "⛓️ Sovereign Pre-Push: TypeScript type-check…"
./node_modules/.bin/tsc --noEmit

echo "✅ Pre-Push gate passed. Sovereign integrity verified."
