STRIPE_SECRET_KEY=sk_live_replace_me
# Webhook URL for Sovereign Creator infraction notifications (licenseGate.js SIG_MISMATCH events)
CREATOR_WEBHOOK_URL=https://replace_with_your_webhook_url
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_CONNECT_REDIRECT_URL=https://example.com/api/stripe/connect/callback
SITE_URL=https://averyos.com
NEXT_PUBLIC_SITE_URL=https://averyos.com
# GitHub PAT for VaultChain real-time commits — set in Render/CI secrets, never hardcoded
GITHUB_PAT=replace_with_your_pat
# Sovereign passphrase for Evidence Vault login gate — set in Cloudflare secret store
VAULT_PASSPHRASE=replace_with_secure_passphrase
# BlockCypher API key for Bitcoin block-height salt on kernel_metadata build timestamps
BLOCKCHAIN_API_KEY=replace_with_blockcypher_token

# ── Sovereign Node Identifiers ────────────────────────────────────────────────
# NODE_01 = Phone (mobile sovereign node)
NODE_01_ID=replace_with_phone_node_id
# NODE_02 = PC (primary workstation sovereign node — runs Llama via Ollama)
NODE_02_ID=replace_with_pc_node_id
# Llama model name loaded in Ollama on NODE_02 (e.g. llama3.3:70b, llama3.1:70b, llama3.2:3b)
NODE_02_LOCAL_MODEL=llama3.3:70b
# Base URL of the Ollama server on NODE_02 (default localhost; change if remote)
NODE_02_OLLAMA_URL=http://localhost:11434

# ── Sovereign Anchor Salt (AveryOS) ───────────────────────────────────────────
# Used to salt the kernel SHA for node-specific handshake verification.
# Keep private — never commit the real value.
SOVEREIGN_ANCHOR_SALT=replace_with_anchor_salt

# ── Cloudflare DNS Verification ──────────────────────────────────────────────
# Zone ID for averyos.com DNS TXT record anchor verification
CLOUDFLARE_ZONE_ID=replace_with_zone_id
# API token scoped to DNS:Read for TXT record sovereign anchor checks
CLOUDFLARE_DNS_API_TOKEN=replace_with_dns_read_token

# ── Firebase — Global Truth Resonance Layer sync ──────────────────────────────
# Server-side (Admin SDK) — set in Cloudflare secret store, never committed
FIREBASE_PROJECT_ID=replace_with_project_id
FIREBASE_CLIENT_EMAIL=replace_with_service_account_email
FIREBASE_PRIVATE_KEY=replace_with_private_key
FIREBASE_DATABASE_URL=replace_with_realtime_db_url

# Client-side (public config) — safe to expose
NEXT_PUBLIC_FIREBASE_API_KEY=replace_with_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=replace_with_auth_domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=replace_with_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=replace_with_storage_bucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace_with_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=replace_with_app_id
# The following files must exist locally but are gitignored (never committed).
# Store them in a secure location (1Password, encrypted vault, or Cloudflare secret store).
#
#   KC.lock.json       — KernelConfiguration cold-storage lock (KC-2026.1)
#   SKC.lock.json      — SovereignKernelConfiguration lock (SKC-2026.1)
#   SST.lock.json      — Startup Sequence Trigger lock
#   ClockGate*.json    — ClockGate verification artifacts
#
# Reference: VaultBridge/GoldenLockArtifact.lock.json contains the SHA-512
# hashes of all private lock files for offline integrity verification.
