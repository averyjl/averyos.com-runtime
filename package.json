{
  "name": "averyos.com-runtime",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "setup": "node scripts/setup.cjs",
    "setup:force": "node scripts/setup.cjs --force",
    "setup:verify": "node scripts/setup.cjs --verify",
    "postinstall": "node scripts/setup.cjs",
    "aos-start": "node scripts/auth.cjs && start \"Watchdog\" cmd /k \"node scripts/watchdog.cjs\" && start \"LicenseGate\" cmd /k \"node scripts/licenseGate.cjs\" && node scripts/lighthouse.cjs",
    "watchdog": "node ./scripts/watchdog.cjs",
    "license-gate": "node ./scripts/licenseGate.cjs",
    "sync:heartbeat": "node scripts/sync-heartbeat.cjs",
    "dev": "next dev",
    "build": "next build",
    "deploy": "npm run pre-deploy:check && npm run build:cloudflare && wrangler deploy && wrangler deploy workers/gabriel-gatekeeper.js --name gabriel-gatekeeper",
    "pre-deploy:check": "npx wrangler d1 migrations apply averyos_kernel_db --remote --dry-run 2>&1 | tee /dev/stderr | grep -qE '(All migrations|No migrations|up to date)' && echo '✅ Migration dry-run passed' || (echo '❌ Migration dry-run failed — fix migrations before deploying' && exit 1)",
    "security:lint": "bash scripts/security-lint.sh",
    "hooks:install": "cp scripts/security-lint.sh .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit && echo '✅ Pre-commit security hook installed'",
    "logs:bouncer": "wrangler tail gabriel-gatekeeper",
    "logs:app": "wrangler tail averyoscom-runtime",
    "build:worker": "npx @opennextjs/cloudflare build",
    "build:cloudflare": "node scripts/patchOpenNextStripe.cjs && node scripts/generate-gates.cjs && npm run capsule:build && npm run capsule:sitemap && node scripts/generate-docs.cjs && npx @opennextjs/cloudflare build",
    "preview": "npx @opennextjs/cloudflare preview",
    "start": "next start",
    "lint": "next lint",
    "test": "next lint",
    "test:unit": "node --loader ./__tests__/loader.mjs --experimental-strip-types --test __tests__/tariUniversal.test.ts __tests__/sovereignKeys.test.ts __tests__/timeMesh.test.ts __tests__/navigationRoutes.test.ts __tests__/wafLogic.test.ts __tests__/driftShield.test.ts __tests__/sovereignError.test.ts __tests__/timePrecision.test.ts __tests__/qaEngine.test.ts __tests__/clearTextStorage.test.ts __tests__/vaultsigWebhook.test.ts && node --test __tests__/generateInvoices.test.cjs",
    "test:unit:ts": "node --loader ./__tests__/loader.mjs --experimental-strip-types --test __tests__/tariUniversal.test.ts __tests__/sovereignKeys.test.ts __tests__/timeMesh.test.ts __tests__/navigationRoutes.test.ts __tests__/wafLogic.test.ts __tests__/driftShield.test.ts __tests__/sovereignError.test.ts __tests__/timePrecision.test.ts __tests__/qaEngine.test.ts __tests__/clearTextStorage.test.ts __tests__/vaultsigWebhook.test.ts",
    "test:unit:cjs": "node --test __tests__/generateInvoices.test.cjs",
    "qa:generate": "node scripts/qaTestGenerator.cjs",
    "qa:generate:verbose": "node scripts/qaTestGenerator.cjs --verbose",
    "qa:generate:force": "node scripts/qaTestGenerator.cjs --force",
    "qa:guard": "node scripts/sovereign-leak-guard.cjs",
    "qa:guard:dry": "node scripts/sovereign-leak-guard.cjs --dry-run",
    "capsule:build": "node scripts/capsulePageAutoCompiler.cjs",
    "capsule:index": "node scripts/capsuleRegistry.cjs",
    "capsule:sitemap": "node scripts/capsuleSitemap.cjs",
    "capsule:sha512": "node scripts/genSha512.cjs",
    "generate:docs": "node scripts/generate-docs.cjs",
    "forge:MeshProofKit_v1": "node scripts/forgeMeshProofKit.cjs",
    "sync:LocalNode_SeedWitnessTraining_v1": "node scripts/localNodeSeedWitnessTraining.cjs",
    "init:TAI_PublicVoteSession": "echo \"Open /tai/public-vote for civic vote bootstrap\"",
    "enforcement:export-evidence": "node scripts/export-evidence.js",
    "enforcement:generate": "node scripts/generateEvidenceBundle.cjs",
    "sovereign:takedown": "node scripts/sovereign-takedown.cjs",
    "sovereign-auth": "node ./scripts/auth.cjs",
    "bridge:verify": "node scripts/verify-repo-ssh.cjs",
    "bridge:verify:ci": "node scripts/verify-repo-ssh.cjs --ci",
    "bridge:verify:verbose": "node scripts/verify-repo-ssh.cjs --verbose",
    "tari-pulse": "node ./scripts/generateEvidenceBundle.cjs",
    "generate:invoices": "node ./scripts/generateInvoices.cjs",
    "persistence:sync": "node ./scripts/persistence-sync.cjs",
    "persistence:once": "node ./scripts/persistence-sync.cjs --once"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "1.17.1",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "express": "5.2.1",
    "express-rate-limit": "8.2.2",
    "firebase": "^12.10.0",
    "isomorphic-dompurify": "2.36.0",
    "katex": "^0.16.35",
    "marked": "17.0.2",
    "next": "15.5.12",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "recharts": "^3.7.0",
    "stripe": "20.4.0"
  },
  "devDependencies": {
    "@types/node": "22.13.5",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.12",
    "eslint-plugin-security": "^4.0.0",
    "typescript": "^5.7.3"
  }
}
