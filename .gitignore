/sha_snapshot.log

# ── Database backups — private, never commit ──────────────────────────────────
# Backups contain hardware identifiers and internal table data.
# Store in an encrypted vault (1Password / Cloudflare R2 private bucket).
backups/*.sql
backups/*.db
backups/*.sqlite

# ── Sovereign runtime state pointers — private ───────────────────────────────
# CurrentVaultHead tracks the live head of the vault — runtime state, not source.
CurrentVaultHead.aoscap
VaultHead.aoscap
VaultHead*.aoscap

# ── Sovereign Sync Manifest — private ────────────────────────────────────────
# .avery-sync.json is the Loop Signature File handshake between Cloudflare
# Workers and Firebase Cloud Functions. It contains live BTC anchor data and
# Firebase credentials — never commit the real file.
# Use .avery-sync.example.json as the template.
.avery-sync.json

# ── Sovereign Evidence Exporter output — never commit generated bundles ───────
# .aoscap bundles are already excluded by the *.aoscap rule above.
# Settlement notice letters and the exports directory are also excluded.
exports/
SETTLEMENT_NOTICE_*.md

# ── Private startup capsule payload — never commit ────────────────────────────
# VaultBridge/encrypt_startup_prompt_to_vaultchain.json holds the full
