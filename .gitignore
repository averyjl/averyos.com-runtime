# ⛓️⚓⛓️ Private Sovereign Runtime Configs — never commit
SKC_*.json
SST_*.json
# KC = Kernel Configuration (voice-transcribed as "Casey" — correct form is KC)
KC_*.json
KC.yaml
KC.yml
# SKC = Sovereign Kernel Configuration
SKC.yaml
SKC.yml
# SST = Sovereign Startup Trigger
SST.yaml
SST.yml
