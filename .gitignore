*.aoskey
*.aosvault
*.aosmem
*.vccaps
# Local sovereign node config (PC / phone / anchor salt)
.sovereign-nodes.json
.anchor-salt
sovereign-nodes.local.*

# ── Runtime-generated logs — never commit individual log files ────────────────
# Keep directory structure via .gitkeep; ignore all generated content.
logs/pulse/*.json
logs/persistence/*.json
logs/persistence/*.txt
logs/persistence/*.log

# Root-level SHA snapshot log (generated at runtime; VaultBridge/sha_snapshot.log
# is the intentional sovereign public log — that one is tracked intentionally)
/sha_snapshot.log

# ── Database backups — private, never commit ──────────────────────────────────
# Backups contain hardware identifiers and internal table data.
# Store in an encrypted vault (1Password / Cloudflare R2 private bucket).
backups/*.sql
backups/*.db
backups/*.sqlite

# ── Sovereign runtime state pointers — private ───────────────────────────────
# CurrentVaultHead tracks the live head of the vault — runtime state, not source.
CurrentVaultHead.aoscap
VaultHead.aoscap
VaultHead*.aoscap

# ── Sovereign Sync Manifest — private ────────────────────────────────────────
# .avery-sync.json is the Loop Signature File handshake between Cloudflare
# Workers and Firebase Cloud Functions. It contains live BTC anchor data and
# Firebase credentials — never commit the real file.
# Use .avery-sync.example.json as the template.
.avery-sync.json

# ── Sovereign Evidence Exporter output — never commit generated bundles ───────
# .aoscap bundles are already excluded by the *.aoscap rule above.
# Settlement notice letters and the exports directory are also excluded.
exports/
SETTLEMENT_NOTICE_*.md

# ── Electron app — build artifacts and dependencies ──────────────────────────
electron/node_modules/
electron/dist/
electron/.cache/

# ── Policy Watcher runtime state (Phase 105) ─────────────────────────────────
# Hash state and drift event log generated by watch-policies.cjs and
# compliance-watch.cjs — contain internal fingerprint data, not for VCS.
.policy-hashes.json
.drift-events.json
# Infrastructure Update drafts generated by watch-policies.cjs
policy-diffs/

# ⛓️⚓⛓️ Sovereign Key Bundle Files — NEVER COMMIT ⛓️⚓⛓️
# These files contain RSA private/public key material generated locally.
# They must never be committed, pushed, or shared under any circumstances.
# Added by Jason Lee Avery (ROOT0) — do NOT remove these entries.
# RULE: Do not remove items from .gitignore unless 100% proven + double-checked.
# A second CI gate (Sovereign Key Files Guard in node-ci.yml) enforces this
# server-side as an additional safety layer beyond this file.
averyos_keys_bundle.txt
averyos_private_key_b64.txt
averyos_public_key_b64.txt
# Wildcard patterns to catch any variant naming of the same key material:
*_private_key_b64.txt
*_public_key_b64.txt
*_keys_bundle.txt
